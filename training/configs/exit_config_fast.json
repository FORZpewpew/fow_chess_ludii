{
    "_comment": "Fast ExIt config for quick testing — 10,000 games only",
    "_usage": "java -Xmx4g -cp 'ludii/Ludii-1.3.14.jar:ludii/agents/jars/agents.jar' training.expert_iteration.ExpertIteration --config ludii/training/configs/exit_config_fast.json",
    "addFeatureEveryN": 500,
    "checkpointEveryN": 2000,
    "expertSearchDepth": -1,
    "expertSearchIterations": -1,
    "expertSearchTime": 0.5,
    "expertType": "UCT",
    "featureSetClasses": [
        "features.spatial.AbsoluteFeature",
        "features.spatial.RelativeFeature"
    ],
    "gameName": "FoW Chess",
    "gameOptions": [],
    "gamePath": "ludii/FoW_Chess.lud",
    "l2RegWeight": 1e-5,
    "learningRate": 0.001,
    "maxNumFeatures": 100,
    "networkType": "LinearFunction",
    "numEpochs": 5,
    "numPlayoutMovesBurnin": 200,
    "numThreads": 4,
    "numTrainingGames": 10000,
    "outputDir": "ludii/training/results/fast/",
    "prioritizeExploredStates": true,
    "pruneInitFeatures": true,
    "trainingBatchSize": 128,
    "useValueFunction": true
}